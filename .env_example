# MySQL (see config/db_conf.py). DATABASE_URL overrides MYSQL_* if set.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Optional: full URL, must use mysql+aiomysql
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/news_app

SQL_ECHO=false
DB_POOL_RECYCLE=3600

# Redis (see config/cache_conf.py). REDIS_URL overrides REDIS_* if set.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI聊天
API_END_POINT=https://dashscope.aliyuncs.com/compatible-mode/v1
API_KEY=
MODEL=